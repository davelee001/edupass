# Frontend Environment Variables
# Copy this to .env (for development) or .env.production (for production builds)

# Backend API URL
# Development
VITE_API_URL=http://localhost:3000/api

# Production (uncomment and update for production builds)
# VITE_API_URL=https://api.yourdomain.com/api

# Stellar Network (for client-side operations)
VITE_STELLAR_NETWORK=testnet
# Options: testnet, public

# Horizon URLs (client-side operations)
VITE_HORIZON_URL_TESTNET=https://horizon-testnet.stellar.org
VITE_HORIZON_URL_PUBLIC=https://horizon.stellar.org

# Feature flags (optional)
VITE_ENABLE_SOROBAN=true
VITE_ENABLE_QR_CODES=true

# Analytics (optional - add your tracking IDs if needed)
# VITE_GA_TRACKING_ID=
# VITE_SENTRY_DSN=
