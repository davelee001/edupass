# Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_NAME=edupass
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=database
DB_PORT=5432

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
API_VERSION=v1
BACKEND_PORT=3000
FRONTEND_PORT=80

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET
JWT_EXPIRES_IN=24h

# ============================================
# STELLAR NETWORK CONFIGURATION
# ============================================
# Options: testnet, public
STELLAR_NETWORK=public

# For Production on Mainnet
HORIZON_URL=https://horizon.stellar.org
SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# For Testing on Testnet
# STELLAR_NETWORK=testnet
# HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ============================================
# ISSUER ACCOUNT CREDENTIALS
# ============================================
# WARNING: Keep these EXTREMELY secure in production!
# Never commit these to version control
ISSUER_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ISSUER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# ASSET CONFIGURATION
# ============================================
ASSET_CODE=EDUPASS
ASSET_LIMIT=10000000

# ============================================
# SOROBAN SMART CONTRACT
# ============================================
# Deploy your contract and add the ID here
SOROBAN_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=https://yourdomain.com
VITE_API_URL=https://api.yourdomain.com/api

# ============================================
# LOGGING
# ============================================
# Options: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# RATE LIMITING
# ============================================
# 15 minutes window
RATE_LIMIT_WINDOW_MS=900000
# 100 requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SECURITY NOTES
# ============================================
# 1. Change ALL default passwords and secrets
# 2. Use strong, randomly generated values
# 3. Store sensitive credentials in secure vault (e.g., AWS Secrets Manager)
# 4. Enable SSL/TLS certificates for production domains
# 5. Configure firewall rules to restrict database access
# 6. Regularly rotate JWT secrets and API keys
# 7. Enable database backups and monitoring
# 8. Use environment-specific configurations
